{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "noEmit": true,
    "ignoreDeprecations": "6.0",
    "types": [
      "vite/client",
      "vitest/globals"
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@components": [
        "src/components/index.ts"
      ],
      "@components/*": [
        "src/components/*"
      ],
      "@composables": [
        "src/composables/index.ts"
      ],
      "@composables/*": [
        "src/composables/*"
      ],
      "@constants": [
        "src/constants/index.ts"
      ],
      "@constants/*": [
        "src/constants/*"
      ],
      "@icons": [
        "src/icons/index.ts"
      ],
      "@icons/*": [
        "src/icons/*"
      ],
      "@plugins": [
        "src/plugins/index.ts"
      ],
      "@plugins/*": [
        "src/plugins/*"
      ],
      "@styles": [
        "src/styles/index.scss"
      ],
      "@styles/*": [
        "src/styles/*"
      ],
      "@ui": [
        "src/components/index.ts"
      ],
      "@ui/*": [
        "src/components/*"
      ],
      "@utils": [
        "src/utils/index.ts"
      ],
      "@utils/*": [
        "src/utils/*"
      ]
    },
    /* Linting — unused-проверки делегированы ESLint (@typescript-eslint/no-unused-vars),
       чтобы не падать на намеренно неиспользуемых переменных в тестах/историях. */
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.vue"
  ]
}