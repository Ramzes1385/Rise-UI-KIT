# Общие CI/CD настройки
# Этот файл — пример. Реальные значения задаются в GitHub/GitLab Variables.

CI=true
NODE_ENV=production

# Включение/отключение пайплайнов
ENABLE_CI=true
ENABLE_RELEASE=false

# Node.js
NODE_VERSION=24

# Release
RELEASE_BRANCH=main
PACKAGE_NAME=@ramzes1385/rise-ui-kit
NPM_REGISTRY_URL=https://registry.npmjs.org/

# npm provenance / trusted publishing
NPM_CONFIG_PROVENANCE=true
