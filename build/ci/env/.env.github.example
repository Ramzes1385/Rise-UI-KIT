# GitHub Actions Variables
# Settings → Secrets and variables → Actions → Variables

ENABLE_CI=true
ENABLE_RELEASE=true
NODE_VERSION=24
RELEASE_BRANCH=main
NPM_CONFIG_PROVENANCE=true

# GitHub Actions Secrets
# Обычно GITHUB_TOKEN создавать не надо — он встроенный.
# Если НЕ используешь npm Trusted Publisher, тогда нужен:
# NPM_TOKEN=your_npm_token

# Рекомендуемый вариант:
# npm Trusted Publisher без NPM_TOKEN.
