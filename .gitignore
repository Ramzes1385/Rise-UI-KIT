# === Test & coverage artifacts ===
coverage/
!coverage/.gitkeep
coverage-run.log
test-results/
playwright-report/
.playwright-mcp/
lighthouse-report.*
lighthouse-report-mobile.*
# tests/ — точечные исключения вместо broad 'tests/': broad не работает с '!' re-include
# (Git запрещает re-include файла, если родительская директория исключена).
tests/**/__screenshots__/
tests/**/*-diff.png
tests/**/*-actual.png
tests/**/*-expected.png
# Visual baselines (Playwright snapshot) — коммитим, CI диффит против них
!tests/visual-snapshots/
!tests/visual-snapshots/**/*.png

# === Tooling caches & analyzer output ===
.eslintcache
*.tsbuildinfo
stats.html

public/icons.svg
